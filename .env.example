COMPOSE_PROJECT_NAME=agentbrowser
SHM_SIZE=2gb

# Selkies live view
SELKIES_WEB_PORT=8080
SELKIES_BASIC_AUTH_USER=operator
SELKIES_BASIC_AUTH_PASSWORD=change-me-webrtc
LINUX_USER_PASSWORD=change-me-linux
SELKIES_PORT=8081
NGINX_PORT=8080
SELKIES_DISPLAY=:20

# TURN/WebRTC (needed by Selkies in container mode per current docs)
SELKIES_TURN_PROTOCOL=udp
SELKIES_TURN_PORT=3478
TURN_MIN_PORT=65532
TURN_MAX_PORT=65535

# Browser/CDP
BROWSER_PROFILE_DIR=/data/profile/chromium
BROWSER_START_URL=about:blank
BROWSER_WINDOW_SIZE=1366,768
BROWSER_CDP_BIND=0.0.0.0
BROWSER_CDP_CONNECT_HOST=127.0.0.1
BROWSER_CDP_PORT=9222
BROWSER_CDP_PROXY_PORT=9223
BROWSER_DISABLE_SANDBOX=false
BROWSER_API_HOST=0.0.0.0
BROWSER_API_PORT=8787
OUTPUT_DIR=/data/output
BROWSER_LOCALE=es-ES
BROWSER_TIMEZONE=Europe/Madrid
TZ=Europe/Madrid
LANG=es_ES.UTF-8
LC_ALL=es_ES.UTF-8
LANGUAGE=es_ES:es
BROWSER_ACCEPT_LANGS=es-ES,es

# Optional generic egress proxy for the container itself
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,browser-appliance

# Optional browser-specific residential proxy injection.
# Leave empty for local residential egress from your own ISP.
# Example for a VPS later:
# BROWSER_PROXY_SERVER=http://user:pass@residential-proxy.example:9000
# BROWSER_PROXY_BYPASS=localhost,127.0.0.1
BROWSER_PROXY_SERVER=
BROWSER_PROXY_BYPASS=localhost,127.0.0.1

# Optional Bitwarden CLI session for secret-blind secure login inside the container.
# Generate it with `bw unlock --raw` and keep it out of agent-visible logs.
BW_SESSION=
BW_CLI=bw
BW_STATE_DIR=/data/profile/bitwarden-state
# Required to persist the Bitwarden session securely across container recreates.
# Use a long random secret and keep it outside agent-visible logs/history.
BW_STATE_KEY=
