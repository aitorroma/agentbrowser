COMPOSE_PROJECT_NAME=agentbrowser-arch
SHM_SIZE=2gb

DESKTOP_SESSION_FLAVOR=noctalia-niri
PRIMARY_COMPOSITOR=niri

SELKIES_WEB_PORT=18080
SELKIES_HTTPS_PORT=18443
SELKIES_WS_PORT=18082
SELKIES_BASIC_AUTH_USER=operator
SELKIES_BASIC_AUTH_PASSWORD=change-me-webrtc
BROWSER_CDP_HOST_PORT=19222
BROWSER_CDP_PORT=9222
BROWSER_CDP_PROXY_PORT=9223
BROWSER_API_HOST_PORT=18787
BROWSER_API_PORT=8787

PIXELFLUX_WAYLAND=true
SELKIES_DESKTOP=true

BROWSER_PROFILE_DIR=/data/profile/chromium
BROWSER_START_URL=about:blank
BROWSER_WINDOW_SIZE=1366,768
BROWSER_CDP_BIND=0.0.0.0
BROWSER_CDP_CONNECT_HOST=127.0.0.1
BROWSER_DISABLE_SANDBOX=false
BROWSER_API_HOST=0.0.0.0
OUTPUT_DIR=/data/output
BROWSER_LOCALE=es-ES
BROWSER_TIMEZONE=Europe/Madrid
TZ=Europe/Madrid
LANG=es_ES.UTF-8
LC_ALL=es_ES.UTF-8
LANGUAGE=es_ES:es
BROWSER_ACCEPT_LANGS=es-ES,es

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,browser-appliance
BROWSER_PROXY_SERVER=
BROWSER_PROXY_BYPASS=localhost,127.0.0.1

BW_SESSION=
BW_CLI=bw
BW_STATE_DIR=/data/profile/bitwarden-state
BW_STATE_KEY=
WEBAUTHN_STATE_DIR=/data/profile/webauthn
